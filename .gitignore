.DS_Store
*.swp
*.swo

# Local Claude Code / great_cto project memory.
# This is the per-project state directory that `npx great-cto init` creates.
# Each user generates their own based on their stack; not committed.
.great_cto/

# Claude Code runtime state — per-session, developer-specific, never committed.
.claude/

# Bundled npm artefacts — CLI package compiles on demand.
packages/cli/node_modules/
packages/cli/*.tgz
packages/cli/dist/

# Wrangler build cache (all workers)
.wrangler/
workers/**/.wrangler/

# Generic node_modules safety net
node_modules/

# DORA baseline — local trend log, not committed.
.great_cto/dora-baseline.log

# SLO burn history — local snapshot series, not committed.
.great_cto/slo-burn-history.log

# Cost history — local cost log, not committed (may contain contract values).
.great_cto/cost-history.log

# Misc
*.log

# Marketing / landing site
# Source files (generators, data, CSS) tracked; generated HTML + binary assets are
# deployment artefacts and remain local-only (regenerate via `node site/_build.mjs`).
site/**/*.html
site/assets/
site/site.webmanifest
site/sitemap.xml
site/robots.txt

# Content drafts (Hashnode articles, social copy) — local only, never committed
content/

# Catalog submission tracking — local progress, not committed
scripts/.catalog-state

# Playwright / UI test artifacts
initial-load.png
t*.png
.playwright-mcp/
.wrangler/
tests/ui/
tests/ui/node_modules/
tests/ui/test-results/
workers/**
# But keep telemetry worker source committed (deployed via wrangler from repo)
!workers/telemetry/
!workers/telemetry/*.ts
!workers/telemetry/*.toml
!workers/telemetry/*.sql
!workers/telemetry/*.md
packages/cli/dist/


# Cursor extension build artifacts
packages/cursor-ext/out/
packages/cursor-ext/node_modules/
packages/cursor-ext/*.vsix
packages/cursor-ext/package-lock.json

# Launch + outreach drafts — local only, never push to public repo
docs/launch/

# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key
tests/**/__pycache__/
*.pyc

# Telemetry insights — internal review only, not published publicly until WAU >= 100
docs/insights/

# Internal QA/maintainer process — kept locally for reference, not committed.
# Removed from public history on 2026-05-10 via git filter-repo (option K).
# Recover historical content via:  git checkout legacy/pre-cleanup-2026-05-10
docs/qa/
docs/INSIGHTS-EMAIL-SETUP.md
tests/board/
tests/eval/fixtures/
tests/eval/*.json
tests/eval/*.jsonl
tests/eval/*.csv
tests/eval/test_*.py
# tracked: tests/eval/EVAL-*.md (reference templates shipped with the plugin)
docs/marketing/
scripts/hashnode-publish.mjs
site/.previews/
